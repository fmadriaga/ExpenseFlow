# Copy this file to .env and fill in your Azure Document Intelligence credentials.
# Never commit the real .env file — it is listed in .gitignore.

# Azure Document Intelligence
AZURE_DI_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/
AZURE_DI_API_KEY=<your-api-key>

# Optional overrides (defaults shown)
AZURE_DI_MAX_RETRIES=3
AZURE_DI_BASE_DELAY=1
WORKER_INTERVAL=60
