<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:ExpenseFlow.Mobile.Converters"
             x:Class="ExpenseFlow.Mobile.DetailPage"
             x:Name="DetailRoot"
             Title="Detalle del ticket">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:OcrStatusColorConverter x:Key="OcrStatusColorConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="*,Auto">

        <!-- Scrollable body -->
        <ScrollView Grid.Row="0" Padding="16,12">
            <VerticalStackLayout Spacing="16">

                <!-- Loading indicator -->
                <ActivityIndicator x:Name="LoadingIndicator"
                                   IsRunning="True"
                                   IsVisible="True"
                                   Color="#2563EB"
                                   HorizontalOptions="Center" />

                <!-- Content (hidden until loaded) -->
                <VerticalStackLayout x:Name="ContentPanel"
                                     IsVisible="False"
                                     Spacing="16">

                    <!-- Status + confidence row -->
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Border Grid.Column="0"
                                StrokeThickness="0"
                                Padding="10,5"
                                BackgroundColor="{Binding OcrStatus, Source={x:Reference DetailRoot}, Converter={StaticResource OcrStatusColorConverter}}"
                                StrokeShape="RoundRectangle 12">
                            <Label x:Name="StatusLabel"
                                   Text="{Binding OcrStatus, Source={x:Reference DetailRoot}, TargetNullValue='?'}"
                                   TextColor="White"
                                   FontSize="13"
                                   FontAttributes="Bold" />
                        </Border>
                        <Label Grid.Column="2"
                               x:Name="ConfidenceLabel"
                               FontSize="13"
                               TextColor="#6B7280"
                               VerticalOptions="Center" />
                    </Grid>

                    <!-- Error message (only when Failed) -->
                    <Frame x:Name="ErrorFrame"
                           IsVisible="False"
                           BackgroundColor="#FEF2F2"
                           BorderColor="#FCA5A5"
                           CornerRadius="8"
                           Padding="12">
                        <Label x:Name="ErrorLabel"
                               TextColor="#991B1B"
                               FontSize="13" />
                    </Frame>

                    <!-- Merchant name -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Comercio"
                               FontSize="12"
                               TextColor="#6B7280"
                               FontAttributes="Bold" />
                        <Entry x:Name="MerchantEntry"
                               Placeholder="Sin nombre"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#111827"
                               BackgroundColor="#F9FAFB"
                               PlaceholderColor="#9CA3AF" />
                    </VerticalStackLayout>

                    <!-- Date + Amount row -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="Fecha"
                                   FontSize="12"
                                   TextColor="#6B7280"
                                   FontAttributes="Bold" />
                            <Entry x:Name="DateEntry"
                                   Placeholder="dd/mm/aaaa"
                                   Keyboard="Numeric"
                                   FontSize="15"
                                   TextColor="#111827"
                                   BackgroundColor="#F9FAFB" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="Total"
                                   FontSize="12"
                                   TextColor="#6B7280"
                                   FontAttributes="Bold" />
                            <Grid ColumnDefinitions="*,Auto">
                                <Entry Grid.Column="0"
                                       x:Name="AmountEntry"
                                       Placeholder="0.00"
                                       Keyboard="Numeric"
                                       FontSize="15"
                                       TextColor="#111827"
                                       BackgroundColor="#F9FAFB" />
                                <Label Grid.Column="1"
                                       x:Name="CurrencyLabel"
                                       FontSize="14"
                                       TextColor="#6B7280"
                                       VerticalOptions="Center"
                                       Margin="4,0,0,0" />
                            </Grid>
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Category -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Categoría"
                               FontSize="12"
                               TextColor="#6B7280"
                               FontAttributes="Bold" />
                        <Label x:Name="CategoryLabel"
                               Text="—"
                               FontSize="15"
                               TextColor="#374151" />
                    </VerticalStackLayout>

                    <!-- Divider -->
                    <BoxView HeightRequest="1" Color="#E5E7EB" />

                    <!-- Items section -->
                    <Label Text="Ítems"
                           FontSize="15"
                           FontAttributes="Bold"
                           TextColor="#111827" />

                    <!-- Items header row -->
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto"
                          ColumnSpacing="8">
                        <Label Grid.Column="0" Text="Descripción" FontSize="11" TextColor="#9CA3AF" />
                        <Label Grid.Column="1" Text="Cant." FontSize="11" TextColor="#9CA3AF" />
                        <Label Grid.Column="2" Text="P.Unit" FontSize="11" TextColor="#9CA3AF" />
                        <Label Grid.Column="3" Text="Total" FontSize="11" TextColor="#9CA3AF" />
                    </Grid>

                    <CollectionView x:Name="LinesCollection"
                                    SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,Auto,Auto,Auto"
                                      ColumnSpacing="8"
                                      Padding="0,6,0,6">
                                    <Label Grid.Column="0"
                                           Text="{Binding Description, TargetNullValue='—'}"
                                           FontSize="13"
                                           TextColor="#374151"
                                           LineBreakMode="TailTruncation" />
                                    <Label Grid.Column="1"
                                           Text="{Binding Quantity, StringFormat='{0:0.##}', TargetNullValue='—'}"
                                           FontSize="13"
                                           TextColor="#374151"
                                           HorizontalOptions="End" />
                                    <Label Grid.Column="2"
                                           Text="{Binding UnitPrice, StringFormat='{0:0.##}', TargetNullValue='—'}"
                                           FontSize="13"
                                           TextColor="#374151"
                                           HorizontalOptions="End" />
                                    <Label Grid.Column="3"
                                           Text="{Binding Amount, StringFormat='{0:0.##}'}"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="#111827"
                                           HorizontalOptions="End" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Label x:Name="NoLinesLabel"
                           Text="Sin ítems detectados"
                           FontSize="13"
                           TextColor="#9CA3AF"
                           IsVisible="False"
                           HorizontalOptions="Center" />

                    <!-- Created at -->
                    <Label x:Name="CreatedAtLabel"
                           FontSize="11"
                           TextColor="#D1D5DB"
                           HorizontalOptions="End" />

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom action bar -->
        <Grid Grid.Row="1"
              x:Name="ActionBar"
              IsVisible="False"
              Padding="16,10,16,20"
              ColumnDefinitions="*,*"
              ColumnSpacing="12"
              BackgroundColor="White">
            <Button Grid.Column="0"
                    x:Name="ReprocessButton"
                    Text="↺ Reprocesar"
                    IsVisible="False"
                    BackgroundColor="#DC2626"
                    TextColor="White"
                    CornerRadius="8"
                    Clicked="OnReprocessClicked" />
            <Button Grid.Column="1"
                    x:Name="SaveButton"
                    Text="✓ Guardar"
                    BackgroundColor="#2563EB"
                    TextColor="White"
                    CornerRadius="8"
                    Clicked="OnSaveClicked" />
        </Grid>

    </Grid>
</ContentPage>
